# FX Scalper — Email Configuration
# Copy this file to .env and fill in your credentials.
# The daemon loads this file automatically via python-dotenv.

# ── SMTP Server ──────────────────────────────────────────────────────────────
# Gmail example (use an App Password, not your account password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.address@gmail.com
SMTP_PASS=your-app-password

# ── Sender / Recipient ────────────────────────────────────────────────────────
# MAIL_FROM defaults to SMTP_USER if left blank.
MAIL_FROM=
# Comma-separate multiple addresses to send to more than one recipient.
MAIL_TO=your.address@gmail.com

# ── Binance API ───────────────────────────────────────────────────────────────
BINANCE_API_KEY=your-api-key
BINANCE_API_SECRET=your-api-secret
BINANCE_TESTNET=true

# ── Crypto trade sizing ────────────────────────────────────────────────────────
# CRYPTO_RISK_USD       : max dollars to risk per trade (qty sized via SL distance)
# CRYPTO_TRADE_SIZE_USD : hard cap on notional value per trade
CRYPTO_RISK_USD=50
CRYPTO_TRADE_SIZE_USD=100

