FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY daemon_crypto.py indicator_btcusd.py mailer.py tradelog.py ./

# trades.jsonl (daemon state) is written at runtime — mount a volume for persistence
ENTRYPOINT ["python", "daemon_crypto.py"]
CMD []
